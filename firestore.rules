rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "msrsr177@gmail.com" ||
        request.auth.token.email == "hamadzabide12345@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Folders
    match /folders/{folderId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Maintenance Records
    match /maintenance_records/{recordId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Price Records
    match /price_records/{priceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Compatibility Records
    match /compatibility_records/{compId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Stats document
    match /stats/counters {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }
    
    // Admins collection (protected)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through console or admin script
    }
  }
}
